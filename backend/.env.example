# Comma-separated extra allowed CORS origins (the deployed frontend URL).
# Any localhost port is always allowed in development.
TRACEFLOW_CORS_ORIGINS=https://your-frontend.vercel.app

# ---- AI explanation layer (all free-tier; optional) ----
# Pick a provider. If unset, auto-detected from whichever key is present below;
# with no key it falls back to deterministic rule-based explanations.
#   gemini | groq | rule
TRACEFLOW_LLM_PROVIDER=gemini

# Google Gemini free tier — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# TRACEFLOW_GEMINI_MODEL=gemini-2.0-flash

# Groq free tier — get a key at https://console.groq.com/keys
GROQ_API_KEY=
# TRACEFLOW_GROQ_MODEL=llama-3.3-70b-versatile
